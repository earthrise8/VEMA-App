rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - email: string (required)
    //   - medicalHistory: string
    //   - createdAt: timestamp
    //
    // Collection: scans
    // Document ID: scanId
    // Fields:
    //   - id: string
    //   - userId: string (required)
    //   - title: string
    //   - description: string
    //   - images: list (required, max 10)
    //   - aiAnalysis: string
    //   - doctorResponse: string
    //   - status: string (required, enum: ['pending', 'analyzed', 'doctor-reviewed'])
    //   - createdAt: timestamp (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.email is string;
    }
    function isValidIssue(data) {
      return data.keys().hasAll(['userId', 'title', 'status']) &&
             data.userId == request.auth.uid &&
             data.status in ['active', 'resolved'];
    }
    function isValidScan(data) {
      return data.keys().hasAll(['userId', 'images', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.images is list && data.images.size() <= 10 &&
             data.status in ['pending', 'analyzed', 'doctor-reviewed'];
    }

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /issues/{issueId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidIssue(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidIssue(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /scans/{scanId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin() || request.auth.uid in resource.data.sharedWith);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidScan(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /consultation_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.expertId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.expertId == request.auth.uid);
    }

    match /experts/{expertId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    match /forum_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated(); // Allow likes and comment count updates
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      }
    }

    match /symptom_logs/{logId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "flyingpig071@gmail.com" && 
             request.auth.token.email_verified == true;
    }
  }
}
