# GEMINI_API_KEY: Required for the backend Gemini API server.
# Keep this server-side only.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: Optional Gemini model id used by the backend.
GEMINI_MODEL="gemini-2.5-flash"

# VITE_API_BASE_URL: Optional backend base URL for the frontend.
# Leave blank for same-origin or Vite proxy based development.
VITE_API_BASE_URL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
